# ============================================================
# JARVIS — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ==========================================
# Voice Interface (TTS/STT)
# ==========================================
VOICE_ENABLED=false
# Can be "piper", "system", or "elevenlabs"
TTS_ENGINE=system
TTS_VOICE=en_US-lessac-medium
STT_MODEL=base
WAKE_WORD_ENABLED=true
PUSH_TO_TALK_KEY=alt
ELEVENLABS_API_KEY=

# NVIDIA API key (required)
# Get one at: https://build.nvidia.com/explore/discover
NVIDIA_API_KEY=nvapi-your-nvidia-api-key-here

# Google Gemini API key (required for Vision features)
# Get one free at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# (Phase 4) Google Calendar / Gmail OAuth credentials — optional
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# (Phase 4) ElevenLabs API key — optional, for premium TTS
# ELEVENLABS_API_KEY=

# (Phase 4) Home Assistant — optional
# HASS_URL=http://homeassistant.local:8123
# HASS_TOKEN=
